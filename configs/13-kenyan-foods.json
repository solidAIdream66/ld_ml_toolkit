{
  "data": {
    "dataset": {
      "type": "CSVFolder",
      "root": "F:/ML_Database/13-kenyan-foods",
      "train_valid_split": 0.8,
      "train_split": "Train",
      "valid_split": "Valid",
      "test_split": "Test"
    },
    "image_size": [
      384,
      384
    ],
    "batch_size": 16,
    "num_workers": 4,
    "pin_memory": true   
  },
  "model": {
    "num_classes": 13,
    "model": {
      "name": "wide_resnet50_2",
      "fine_tune_start": 1,
      "weights": "DEFAULT"
    },
    "use_batch_norm": true,
    "dropout": 0.1
  },
  "train": {
    "epochs": 20,
    "learning_rate": 1e-5,
    "weight_decay": 1e-4,
    "label_smoothing": 0.02,
    "device": "cuda",
    "seed": 202,
    "optimizer_type": "adamw",
    "loss_type": "cross_entropy",
    "metric_type": "accuracy",
    "logger_type": "tensorboard",
    "use_augmentation": true,
    "scheduler": {
      "name": "plateau",
      "factor": 0.5,
      "patience": 2,
      "early_stop": {
        "enabled": true,
        "monitor": "valid/loss",
        "mode": "min",
        "patience": 5,
        "min_delta": 0.0,
        "verbose": true
      }   
    },
    "precision": "bf16-mixed",
    "deterministic": false,
    "matmul_precision": "high",
    "extras": {
      "scheduler": {
        "cosine_warm_restarts": {
          "t0": 10,
          "t_mult": 2,
          "eta_min": 1e-05
        },
        "cosine": {
          "t0": 10,
          "t_mult": 2,
          "eta_min": 1e-05
        },
        "cosineannealingwarmrestarts": {
          "t0": 10,
          "t_mult": 2,
          "eta_min": 1e-05
        },
        "plateau": {
          "factor": 0.5,
          "patience": 3
        },
        "reduce_on_plateau": {
          "factor": 0.5,
          "patience": 3
        },
        "reducelronplateau": {
          "factor": 0.5,
          "patience": 3
        }
      }
    }
  },
  "paths": {
    "checkpoint_dir": "Logs_Checkpoints\\Model_checkpoints",
    "log_dir": "Logs_Checkpoints\\Model_logs",
    "model_name": "13-kenyan-foods-classifier.pt",
    "experiments_file": "Logs_Checkpoints/experiments.xlsx"
  },
  "extras": {    
    "exp_name": "wide_resnet50_2_img320_bs8_ftfull_seed202"
  }
}
